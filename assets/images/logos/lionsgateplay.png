  <base href="/">

  <meta charset="UTF-8">
  <meta content="IE=Edge" http-equiv="X-UA-Compatible">
  <meta name="description"
    content="Stream blockbuster Hollywood movies, binge-worthy TV shows, web series & exclusive originals on Lionsgate Play. Watch online in HD with exclusive premieres & popular entertainment.">

  <!-- Cache Control Meta Tags to prevent browser caching -->
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">

  <!-- iOS meta tags & icons -->
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black">
  <meta name="apple-mobile-web-app-title" content="lionsgateplay">
  <link rel="apple-touch-icon" href="icons/Icon-192.png">

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="favicon.png" />

  <title>Watch Hollywood Movies, TV Shows & Web Series Online on Lionsgate Play</title>
  <link rel="manifest" href="manifest.json">


  <!-- Shaka Player for video streaming on web -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/shaka-player/4.7.11/shaka-player.compiled.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/shaka-player/4.7.11/controls.min.css">
  <script src="shaka_player.js?v=20&t=20260709k"></script>

  <!-- CleverTap Web SDK -->
  <script src="./assets/packages/clevertap_plugin/assets/clevertap.js"></script>


  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #000000;
    }

    .loader-container {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      display: flex;
      justify-content: center;
      align-items: center;
      background-color: #000000;
      z-index: 9999;
    }

    .loader {
      width: 50px;
      height: 50px;
      border: 5px solid rgba(255, 255, 255, 0.2);
      border-top-color: #ffffff;
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }
  </style>
</head>

<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PJX9XGC4" height="0" width="0"
      style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  <div class="loader-container" id="loading">
    <div class="loader"></div>
  </div>
  <script>
    document.write('<script src="flutter_bootstrap.js?v=' + new Date().getTime() + '" async><\/script>');
  </script>
  <script>
    // Hide loader after 1 second regardless
    setTimeout(() => {
      document.getElementById('loading').style.display = 'none';
    }, 1000);

    window.addEventListener('flutter-first-frame', function () {
      document.getElementById('loading').style.display = 'none';
    });
  </script>
</body>

</html>